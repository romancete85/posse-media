# Copiar a .env y completar. NUNCA commitear el .env real (ver .gitignore).

# --- App de LinkedIn (https://www.linkedin.com/developers/apps) ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8765/callback
# Version de la Posts API (formato YYYYMM). LinkedIn rota ~12 meses; mantener actual.
LINKEDIN_VERSION=202606

# --- OAuth local (flujo de una sola vez) ---
OAUTH_CALLBACK_PORT=8765

# --- AWS / token store (SSM Parameter Store, SecureString) ---
AWS_REGION=us-east-1
# Path base del parametro donde viven los tokens (SecureString + KMS).
SSM_TOKEN_PARAM=/posse-pipeline/linkedin/tokens
# En CI, las credenciales AWS vienen de GitHub Secrets (access key). En local, del perfil/CLI de AWS.

# --- Backend del token store: "ssm" (prod/CI) | "local" (dev) ---
TOKEN_STORE_BACKEND=local
# Solo para el backend local (dev): archivo fuera del repo.
LOCAL_TOKEN_FILE=~/.config/posse-pipeline/tokens.json

# --- Contenido ---
CONTENT_DIR=content

# --- Generación con IA (produce siempre drafts; el gate humano sigue intacto) ---
# Texto: "ollama" (homelab, gratis) | "claude" (API, con créditos)
LLM_BACKEND=ollama
# Ollama del homelab: CT 120 en minipve2 (ver proxmox-ai-ops/docs/OLLAMA-AIBOX.md).
# ⚠️ DHCP .154 — conviene reserva de IP; si cambia, actualizá acá.
OLLAMA_HOST=http://192.168.100.154:11434
OLLAMA_MODEL=llama3.2:3b   # rápido en CPU. qwen2.5:7b = más calidad pero lento (timeout en CPU).
# Claude (solo si LLM_BACKEND=claude). Vacío -> el SDK usa el entorno.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
# Imágenes (Google): Imagen genera, Gemini visión escribe el alt (misma key).
GEMINI_API_KEY=
IMAGEN_MODEL=imagen-4.0-generate-001
GEMINI_VISION_MODEL=gemini-2.5-flash

# Copiar a .env y completar. NUNCA commitear el .env real (ver .gitignore).

# --- App de LinkedIn (https://www.linkedin.com/developers/apps) ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8765/callback
# Version de la Posts API (formato YYYYMM). LinkedIn la actualiza; se loguea en cada request.
LINKEDIN_VERSION=202506

# --- OAuth local (flujo de una sola vez) ---
OAUTH_CALLBACK_PORT=8765

# --- AWS / token store (SSM Parameter Store, SecureString) ---
AWS_REGION=us-east-1
# Path base del parametro donde viven los tokens (SecureString + KMS).
SSM_TOKEN_PARAM=/posse-pipeline/linkedin/tokens
# En CI, las credenciales AWS vienen de GitHub Secrets (access key). En local, del perfil/CLI de AWS.

# --- Backend del token store: "ssm" (prod/CI) | "local" (dev) ---
TOKEN_STORE_BACKEND=local
# Solo para el backend local (dev): archivo fuera del repo.
LOCAL_TOKEN_FILE=~/.config/posse-pipeline/tokens.json

# --- Contenido ---
CONTENT_DIR=content
